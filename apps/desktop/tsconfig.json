{
  "extends": "@qwery/tsconfig/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "paths": {
      "~/*": ["./app/*", "../web/app/*"],
      "~/config/*": ["./config/*", "../web/config/*"],
      "~/components/*": ["./components/*", "../web/components/*"],
      "~/lib/*": ["./lib/*", "../web/lib/*"],
      "~/types/*": ["./.react-router/types/*", "../web/.react-router/types/*"]
    },
    "noEmit": true,
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json",
    "rootDirs": [".", "./.react-router/types"]
  },
  "include": [
    "src",
    "app"
  ],
  "exclude": ["node_modules"]
}