{
  "name": "@qwery/semantic-layer",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --coverage",
    "test:watch": "vitest"
  },
  "prettier": "@qwery/prettier-config",
  "exports": {
    "./discovery": "./src/discovery.service.ts",
    "./types": "./src/types.ts",
    "./store": "./src/schema-store.ts",
    "./on-attach": "./src/on-datasource-attach.ts",
    "./semantic-model": "./src/semantic-model/semantic-model.service.ts",
    "./osi-types": "./src/osi/types.ts",
    "./ontology": "./src/ontology/ontology.service.ts",
    "./data-agent": "./src/data-agent/data-agent.service.ts"
  },
  "typesVersions": {
    "*": {
      "discovery": [
        "src/discovery.service.ts"
      ],
      "types": [
        "src/types.ts"
      ],
      "store": [
        "src/schema-store.ts"
      ],
      "on-attach": [
        "src/on-datasource-attach.ts"
      ],
      "semantic-model": [
        "src/semantic-model/semantic-model.service.ts"
      ],
      "osi-types": [
        "src/osi/types.ts"
      ],
      "ontology": [
        "src/ontology/ontology.service.ts"
      ],
      "data-agent": [
        "src/data-agent/data-agent.service.ts"
      ],
      "*": [
        "src/*"
      ]
    }
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/openai": "^1.3.1",
    "@qwery/domain": "workspace:*",
    "@qwery/extensions-loader": "workspace:*",
    "@qwery/extensions-sdk": "workspace:*",
    "@qwery/shared": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "neo4j-driver": "^6.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@qwery/eslint-config": "workspace:*",
    "@qwery/prettier-config": "workspace:*",
    "@qwery/tsconfig": "workspace:*",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "^9.39.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
