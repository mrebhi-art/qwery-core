
# Storage
QWERY_STORAGE_DIR=qwery.db

# Extensions discovery
QWERY_EXTENSIONS_PATH=

# Azure OpenAI
AZURE_API_KEY=
AZURE_RESOURCE_NAME=
AZURE_OPENAI_DEPLOYMENT=

# Anthropic
ANTHROPIC_API_KEY=

# Neo4j
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpass

# Ollama Cloud
AGENT_PROVIDER=ollama-cloud
OLLAMA_API_KEY=
OLLAMA_MODEL=minimax-m2.7

# Telemetry
QWERY_TELEMETRY_ENABLED=false
QWERY_TELEMETRY_DEBUG=false

# Default model
DEFAULT_MODEL=ollama-cloud/minimax-m2.7

# Tracing microservice
TRACING_BASE_URL=http://localhost:4097
TRACING_API_KEY=local-dev
TRACING_PROJECT_ID=semantic-qwery-core
