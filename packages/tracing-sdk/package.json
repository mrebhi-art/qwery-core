{
  "name": "@qwery/tracing-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./eval": {
      "import": "./src/eval/index.ts",
      "types": "./src/eval/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"**/*.ts\"",
    "format:fix": "prettier --write \"**/*.ts\"",
    "test": "vitest run --logHeapUsage --coverage --silent",
    "test:watch": "vitest"
  },
  "prettier": "@qwery/prettier-config",
  "dependencies": {
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@qwery/eslint-config": "workspace:*",
    "@qwery/prettier-config": "workspace:*",
    "@qwery/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "^9.39.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
