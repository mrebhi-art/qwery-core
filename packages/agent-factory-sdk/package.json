{
  "name": "@qwery/agent-factory-sdk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --logHeapUsage --coverage --silent",
    "test:watch": "vitest",
    "eval": "node node_modules/@qwery/evals/bin/evals.mjs run __evals__",
    "evals:report": "node node_modules/@qwery/evals/bin/evals.mjs report __evals__",
    "evals:preview": "node node_modules/@qwery/evals/bin/evals.mjs preview __evals__",
    "eval:suite": "bun evals-regression/suites/single-turn/ask-eval-suite.ts",
    "eval:suite:ask": "bun evals-regression/suites/single-turn/ask-eval-suite.ts",
    "eval:suite:sql": "bun evals-regression/suites/single-turn/sql-quality-eval-suite.ts",
    "eval:suite:chart": "bun evals-regression/suites/single-turn/chart-generation-eval-suite.ts",
    "eval:suite:chart-pipeline": "bun evals-regression/suites/single-turn/chart-pipeline-eval-suite.ts",
    "eval:suite:tools": "bun evals-regression/suites/single-turn/tool-sequence-eval-suite.ts",
    "eval:suite:safety": "bun evals-regression/suites/single-turn/destructive-safety-eval-suite.ts",
    "eval:suite:intents": "bun evals-regression/suites/single-turn/expanded-intent-eval-suite.ts",
    "eval:suite:latency": "bun evals-regression/suites/single-turn/latency-token-eval-suite.ts",
    "eval:suite:mustache-token": "bun evals-regression/suites/single-turn/mustache-token-optimization-eval-suite.ts",
    "eval:suite:mustache-impact": "bun evals-regression/suites/single-turn/mustache-impact-execution-eval-suite.ts",
    "eval:suite:multi-turn": "bun evals-regression/suites/multi-turn/multi-turn-ask-eval-suite.ts",
    "eval:suite:context-retention": "bun evals-regression/suites/multi-turn/context-retention-eval-suite.ts",
    "eval:suite:conv-correction": "bun evals-regression/suites/multi-turn/conversation-correction-eval-suite.ts",
    "eval:benchmark:bird": "bun evals-regression/suites/benchmarks/bird-eval-suite.ts",
    "eval:benchmark:bird:loop": "bun evals-regression/suites/benchmarks/bird-local-loop.ts",
    "eval:benchmark:bird:schools": "bun evals-regression/suites/benchmarks/bird-california-schools.ts",
    "eval:benchmark:bird:formula1": "bun evals-regression/suites/benchmarks/bird-formula1.ts",
    "eval:benchmark:bird:build-ontology": "bun scripts/internal-agent/build-bird-ontology.ts",
    "eval:benchmark:bird:build-ontology:schools": "bun scripts/internal-agent/build-bird-ontology.ts --dataset california_schools",
    "eval:benchmark:bird:build-ontology:formula1": "bun scripts/internal-agent/build-bird-ontology.ts --dataset formula_1",
    "eval:dataset:push": "bun evals-regression/datasets/push-all.ts",
    "eval:report:mustache-impact": "node evals-regression/reports/compile-mustache-impact-report.mjs",
    "eval:report:latency-impact": "node evals-regression/reports/compile-latency-impact-report.mjs",
    "eval:regression": "node evals-regression/runner.mjs",
    "eval:regression:check": "node scripts/regression-check.mjs"
  },
  "exports": {
    ".": {
      "browser": "./src/browser.ts",
      "default": "./src/index.ts"
    },
    "./config": "./src/config/index.ts",
    "./config/node": "./src/config/node.ts",
    "./llm": "./src/llm/index.ts",
    "./mcp": "./src/mcp/index.ts",
    "./tools/datasource-name-utils": "./src/tools/datasource-name-utils.ts",
    "./tools/datasource-loader": "./src/tools/datasource-loader.ts",
    "./services/duckdb-query-engine.service": "./src/services/duckdb-query-engine.service.ts"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^3.0.61",
    "@ai-sdk/anthropic": "^2.0.49",
    "@ai-sdk/azure": "^2.0.73",
    "@ai-sdk/mcp": "^1.0.0",
    "@ai-sdk/openai": "^3.0.21",
    "@ai-sdk/openai-compatible": "^1.0.0",
    "@ai-sdk/react": "^3.0.60",
    "@aws-sdk/client-s3": "^3.936.0",
    "@aws-sdk/credential-providers": "^3.936.0",
    "@browser-ai/core": "^2.0.1",
    "@browser-ai/transformers-js": "^2.0.1",
    "@browser-ai/web-llm": "^2.0.1",
    "@duckdb/node-api": "1.4.2-r.1",
    "@mlc-ai/web-llm": "^0.2.79",
    "@opentelemetry/api": "^1.9.0",
    "@qwery/domain": "workspace:*",
    "@qwery/extensions-loader": "workspace:*",
    "@qwery/extensions-sdk": "workspace:*",
    "@qwery/semantic-layer": "workspace:*",
    "@qwery/shared": "workspace:*",
    "@qwery/telemetry": "workspace:*",
    "ai": "catalog:",
    "ai-sdk-ollama": "^3.3.0",
    "gray-matter": "^4.0.3",
    "i": "^0.3.7",
    "mustache": "^4.2.0",
    "nanoid": "^5.1.6",
    "npm": "^11.6.4",
    "turndown": "^7.2.2",
    "uuid": "catalog:",
    "xstate": "^5.24.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@qwery/eslint-config": "workspace:*",
    "@qwery/evals": "workspace:*",
    "@qwery/i18n": "workspace:*",
    "@qwery/prettier-config": "workspace:*",
    "@qwery/repository-in-memory": "workspace:*",
    "@qwery/tailwind-config": "workspace:*",
    "@qwery/tracing-sdk": "workspace:*",
    "@qwery/tsconfig": "workspace:*",
    "@qwery/ui": "workspace:*",
    "@radix-ui/react-icons": "^1.3.2",
    "@tanstack/react-query": "catalog:",
    "@types/mustache": "^4.2.6",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "^9.39.0",
    "lucide-react": "^0.552.0",
    "memfs": "^4.51.0",
    "msw": "^2.12.2",
    "next-themes": "0.4.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^16.2.3",
    "sonner": "^2.0.7",
    "testcontainers": "^10.12.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@qwery/prettier-config",
  "typesVersions": {
    "*": {
      "domain": [
        "src/domain/index.ts"
      ],
      "ports": [
        "src/ports/index.ts"
      ],
      "services": [
        "src/services/index.ts"
      ],
      "*": [
        "src/*"
      ]
    }
  }
}