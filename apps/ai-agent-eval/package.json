{
  "name": "@qwery/ai-agent-eval",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts | pino-pretty",
    "start": "bun run src/index.ts",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"**/*.ts\"",
    "format:fix": "prettier --write \"**/*.ts\"",
    "test": "vitest run --logHeapUsage --coverage --silent",
    "test:watch": "vitest",
    "db:migrate": "bun run src/infrastructure/persistence/migrate.ts"
  },
  "prettier": "@qwery/prettier-config",
  "dependencies": {
    "@hono/zod-validator": "^0.4.2",
    "@qwery/shared": "workspace:*",
    "hono": "^4.10.7",
    "postgres": "^3.4.5",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@qwery/eslint-config": "workspace:*",
    "@qwery/prettier-config": "workspace:*",
    "@qwery/tsconfig": "workspace:*",
    "@types/bun": "latest",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "^9.39.0",
    "pino-pretty": "^13.1.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.x"
  }
}
